# .env Configuration File for Zero Trust Framework

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-12345
JWT_ALGORITHM=HS256

# MongoDB Configuration (optional - in-memory storage used for demo)
MONGO_URI=mongodb://localhost:27017/zerotrust_db

# CORS Configuration
CORS_ORIGINS=http://localhost:3000

# Application Port
PORT=5000

# Domain Configuration
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Feature Flags
ENABLE_BLOCKCHAIN_AUDIT=True
ENABLE_RISK_SCORING=True
ENABLE_ABAC=True
ENABLE_RBAC=True

# Risk Scoring Thresholds
RISK_HIGH_THRESHOLD=70
RISK_CRITICAL_THRESHOLD=85

# Authentication Settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=zerotrust.log
